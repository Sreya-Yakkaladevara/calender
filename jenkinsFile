pipeline {
    agent any

        stage('Build Application') {
            steps {
                // Do the same for the build step
                dir('my-calendar') {
                    echo 'Building production bundle...'
                    sh 'npm run dev'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check the build logs for details.'
        }
    }
}
