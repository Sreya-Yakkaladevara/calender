pipeline {
    agent {
        docker{
            image 'node:22-alpine'
        }

    }

    stages {
        stage('Build Application') {
            steps {
                dir('my-calendar') {
                    echo 'Installing dependencies and building production bundle...'
                    sh 'npm install --cache ./npm-cache'
                    sh 'npm install'
                    sh 'npm run dev'
                }
            }
        }
        stage('Test') {
            steps {
                sh 'node --version'  
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check the build logs for details.'
        }
    }
}
