pipeline {
    agent any

    tools {
        // Ensure 'node' matches the exact name in Jenkins Global Tool Configuration
        nodejs 'node' 
    }

    stages {
        stage('Install Dependencies') {
            steps {
                echo 'Installing npm packages...'
                sh 'npm install'
            }
        }

        stage('Build Application') {
            steps {
                echo 'Building production bundle...'
                // CHANGED: Use 'npm run build' for a production bundle. 
                // 'npm run dev' spins up a persistent local server and will hang Jenkins forever.
                sh 'npm run build'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check the build logs for details.'
        }
    }
}
